# react-native_write_safety.rules
# Technology: react-native | Capability: write

rule react-native-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "dangerouslySetInnerHTML"
  MESSAGE "Blocked an unsafe pattern in react-native. Use the recommended best practices for 2025/2026."
}

rule react-native-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "AsyncStorage"
  MESSAGE "You are using an outdated API for react-native. Please upgrade to the newer API."
}
